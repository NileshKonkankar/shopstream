# Port number for the Express server
PORT=5000

# Environment mode (development, production, test)
NODE_ENV=development

# MongoDB connection URI (e.g., local MongoDB or MongoDB Atlas)
MONGO_URI=mongodb://localhost:27017/shopstream

# JWT configuration
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d

# Frontend client URL (for CORS and Socket.IO authorization)
CLIENT_URL=http://localhost:5173

# Stripe payment configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Currency configuration (defaults to INR)
CURRENCY=INR
